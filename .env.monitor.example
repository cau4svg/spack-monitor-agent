# Telegram
BOT_TOKEN=__SET_BOT_TOKEN__
CHAT_ID=__SET_CHAT_ID__

# Auto-derived by install.sh on each server.
PM2_NAME=apiwhatsapp-XXXX
SERVER_NAME=WHATSAPP-XXXX
HOST_LABEL=187
HEALTH_URL=https://apiwhatsapp-XXXX.apibrasil.com.br

# PM2 runtime discovery.
PM2_BIN=/root/.nvm/versions/node/v20.0.0/bin/pm2
PM2_HOME=/root/.pm2

# Monitor behavior.
CHECK_INTERVAL_SECONDS=10
CURL_TIMEOUT_SECONDS=10
HEALTH_OK_HTTP_CODES_REGEX=^(2|3)[0-9][0-9]$
TELEGRAM_API_BASE=https://api.telegram.org

# Directories created under /opt/spack-monitor during installation.
STATE_DIR=/opt/spack-monitor/state
LOG_DIR=/opt/spack-monitor/logs
